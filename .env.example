# Backend API (state) - dev default
VITE_API_BASE_URL=http://localhost:3001

# Supabase: WAJIB sama project-nya dengan backend (state/.env).
# Kalau backend pakai Supabase Cloud → isi Project URL + anon key dari Dashboard (Settings → API).
# Kalau backend pakai Supabase local → isi http://127.0.0.1:54321 + anon key dari `supabase status`.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_from_same_project
